<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Host Dashboard - BOOKIFYSTAY</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/header') %>
    
    <main class="container mt-5 mb-5">
        <h2 class="mb-4"><i class="fas fa-tachometer-alt"></i> My Host Dashboard</h2>
        <p class="text-muted">Manage your property booking requests here.</p>

        <% if (bookings.length === 0) { %>
            <div class="alert alert-info">
                You don't have any booking requests yet.
            </div>
        <% } else { %>
            <div class="row">
                <% for(let booking of bookings) { %>
                    <div class="col-md-6 mb-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-header d-flex justify-content-between align-items-center 
                                <%= booking.status === 'pending' ? 'bg-warning text-dark' : (booking.status === 'accepted' ? 'bg-success text-white' : 'bg-danger text-white') %>">
                                <strong>Status: <%= booking.status.toUpperCase() %></strong>
                                <small>Req. Date: <%= booking.createdAt.toLocaleDateString() %></small>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title"><i class="fas fa-home"></i> <%= booking.listing ? booking.listing.title : 'Deleted Listing' %></h5>
                                <hr>
                                <p class="mb-1"><strong><i class="fas fa-envelope"></i> Guest Email:</strong> <%= booking.guestEmail %></p>
                                <p class="mb-1"><strong><i class="fas fa-calendar-alt"></i> Check-in:</strong> <%= booking.checkIn.toLocaleDateString() %></p>
                                <p class="mb-1"><strong><i class="fas fa-calendar-alt"></i> Check-out:</strong> <%= booking.checkOut.toLocaleDateString() %></p>
                                <h5 class="mt-3 text-primary">Total: ₹ <%= booking.totalPrice.toLocaleString("en-IN") %></h5>
                            </div>
                            
                            <% if(booking.status === 'pending') { %>
                                <div class="card-footer bg-white d-flex justify-content-end gap-2">
                                    <form action="/listing/booking/<%= booking._id %>/reject" method="POST">
                                        <button class="btn btn-outline-danger btn-sm"><i class="fas fa-times"></i> Reject</button>
                                    </form>
                                    <form action="/listing/booking/<%= booking._id %>/accept" method="POST">
                                        <button class="btn btn-success btn-sm"><i class="fas fa-check"></i> Accept Request</button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Trips - BOOKIFYSTAY</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/header') %>
    
    <main class="container mt-5 mb-5">
        <h2 class="mb-4"><i class="fas fa-suitcase-rolling"></i> My Trips</h2>
        <p class="text-muted">Keep track of all your adventures here.</p>

        <% if (trips.length === 0) { %>
            <div class="alert alert-info">
                <i class="fas fa-plane-departure me-2"></i> You haven't booked any trips yet! <a href="/listing" class="alert-link">Start exploring</a>.
            </div>
        <% } else { %>
            <div class="row">
                <% for(let trip of trips) { %>
                    <div class="col-md-6 mb-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-header d-flex justify-content-between align-items-center 
                                <%= trip.status === 'pending' ? 'bg-warning text-dark' : (trip.status === 'accepted' ? 'bg-success text-white' : 'bg-danger text-white') %>">
                                <strong>
                                    <% if(trip.status === 'pending') { %><i class="fas fa-hourglass-half"></i> PENDING HOST APPROVAL
                                    <% } else if(trip.status === 'accepted') { %><i class="fas fa-check-circle"></i> CONFIRMED
                                    <% } else { %><i class="fas fa-times-circle"></i> CANCELLED / REJECTED
                                    <% } %>
                                </strong>
                                <small>Booked: <%= trip.createdAt.toLocaleDateString() %></small>
                            </div>
                            
                            <div class="card-body row">
                                <div class="col-4">
                                    <% if (trip.listing && trip.listing.image) { %>
                                        <img src="<%= trip.listing.image.url || trip.listing.image %>" alt="Property" class="img-fluid rounded" style="height: 100px; object-fit: cover; width: 100%;">
                                    <% } else { %>
                                        <div class="bg-secondary rounded h-100 w-100 d-flex justify-content-center align-items-center text-white">
                                            <i class="fas fa-image"></i>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="col-8">
                                    <h5 class="card-title"><%= trip.listing ? trip.listing.title : 'Listing Unavailable' %></h5>
                                    <p class="mb-1 text-muted small"><i class="fas fa-calendar-alt"></i> <%= trip.checkIn.toLocaleDateString() %> &rarr; <%= trip.checkOut.toLocaleDateString() %></p>
                                    <h5 class="mt-2 text-primary">₹ <%= trip.totalPrice.toLocaleString("en-IN") %></h5>
                                </div>
                            </div>
                            
                            <% if(trip.status === 'accepted') { %>
                                <div class="card-footer bg-light">
                                    <small class="text-muted"><i class="fas fa-info-circle"></i> Check your email (<%= trip.guestEmail %>) for host instructions.</small>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </main>

    <%- include('partials/footer') %>
</body>
</html>